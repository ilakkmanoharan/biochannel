# Copy this file to `.env` in the same folder as `app.py`:
#   cp .env.example .env
# Then paste your API key on the line below (no quotes needed).
#
# Get a key: https://aistudio.google.com/apikey
# (Google AI Studio → Create API key)

GOOGLE_API_KEY=

# Optional: override the Gemini model name (default: gemini-2.0-flash)
# BIOCHANNEL_GEMINI_MODEL=gemini-2.0-flash
